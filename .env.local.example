# ─── Supabase ────────────────────────────────────────────────────────────────
# Proyecto → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ⚠️  NUNCA uses el prefijo NEXT_PUBLIC_ en esta clave — es solo para el servidor
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── CSRF ────────────────────────────────────────────────────────────────────
# Cadena aleatoria de mínimo 32 caracteres para firmar tokens CSRF (HMAC-SHA256)
# Genera una con: openssl rand -hex 32
CSRF_SECRET=your-random-32-char-secret-here

# ─── Rate Limiting ───────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=600000
RATE_LIMIT_MAX_REQUESTS=5
